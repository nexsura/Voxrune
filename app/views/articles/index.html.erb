<main>
  <h1>Articles</h1>

  <% if @articles.any? %>
    <% @articles.each do |article| %>
      <article>
        <h2><%= article.title %></h2>

        <% if article.excerpt.present? %>
          <p><%= article.excerpt %></p>
        <% end %>

        <p>
          Published on
          <time datetime="<%= article.published_at.iso8601 %>">
            <%= article.published_at.to_date.to_fs(:long) %>
          </time>
        </p>
      </article>
    <% end %>
  <% else %>
    <p>No published articles yet.</p>
  <% end %>
</main>
